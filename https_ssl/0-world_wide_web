#!/usr/bin/env bash
# Displays information about subdomains of a given domain.
# shellcheck disable=SC2086

# Function to display subdomain info
display_subdomain_info() {
    local domain=$1
    local subdomain=$2
    local info
    
    # Get the DNS record info robustly using awk
    # It looks for the ANSWER SECTION and picks the first line that doesn't start with ;
    info=$(dig "$subdomain.$domain" | awk '/ANSWER SECTION:/ {flag=1; next} flag && /^[^;]/ {print $4, $5; exit}')
    
    # Extract record type and destination
    local record_type
    record_type=$(echo "$info" | awk '{print $1}')
    local destination
    destination=$(echo "$info" | awk '{print $2}')

    # Output: The subdomain [SUB_DOMAIN] is a [RECORD_TYPE] record and points to [DESTINATION]
    if [ -n "$destination" ]; then
        echo "The subdomain $subdomain is a $record_type record and points to $destination"
    fi
}

# Main script logic
DOMAIN=$1
SUBDOMAIN=$2

if [ -z "$SUBDOMAIN" ]; then
    # When only domain is provided, display info for default ones in specific order
    display_subdomain_info "$DOMAIN" "www"
    display_subdomain_info "$DOMAIN" "lb-01"
    display_subdomain_info "$DOMAIN" "web-01"
    display_subdomain_info "$DOMAIN" "web-02"
else
    # When domain and subdomain are provided, display info for specified subdomain
    display_subdomain_info "$DOMAIN" "$SUBDOMAIN"
fi
